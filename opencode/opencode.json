{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "bash": {
      "gh *": "deny",

      "git status*": "allow",
      "git diff*": "allow",
      "git log*": "allow",
      "git branch*": "allow",
      "git remote*": "allow",

      "gh pr view*": "allow",
      "gh pr list*": "allow",
      "gh pr status*": "allow",
      "gh issue view*": "allow",
      "gh issue list*": "allow",
      "gh run list*": "allow",
      "gh run view*": "allow",
      "gh repo view*": "allow",

      "git push*": "deny"
    }
  }
}
